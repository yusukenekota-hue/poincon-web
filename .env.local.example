# Supabaseプロジェクト設定 → https://supabase.com/dashboard/project/_/settings/api
# このファイルを .env.local にコピーして値を埋めてください(.env.local はgit管理外)。
# 必ずEUリージョン(RGPD対応)で作成したプロジェクトを使うこと。

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー専用。管理画面の承認/却下処理でのみ使用し、絶対にクライアントに渡さないこと。
SUPABASE_SERVICE_ROLE_KEY=

# /admin へのアクセスを許可するユーザー名(カンマ区切り、profiles.usernameと照合)
ADMIN_USERNAMES=mimizu
